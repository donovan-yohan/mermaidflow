{
  "name": "@mermaidflow/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mermaidflow/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "tsx": "4.20.5",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
